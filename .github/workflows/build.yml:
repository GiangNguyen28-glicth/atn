name: Build Spark Image
on: workflow_dispatch

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Build image
        run: docker build -t spark-runtime:1.0.2 .

      - name: Save and compress image
        run: docker save spark-runtime:1.0.2 | gzip > spark-runtime-1.0.2.tar.gz

      - name: Upload artifact
        uses: actions/upload-artifact@v4
        with:
          name: spark-runtime-image
          path: spark-runtime-1.0.2.tar.gz
          retention-days: 3
